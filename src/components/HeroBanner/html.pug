//-------------------------------------------------------------------------------
  @name: Hero Banner
  -------------------------------------------------------------------------------//

='\n\n'
//.hero-banner
.hero-banner
  .hero-banner-inner.js-hero-banner
    each val, idx in data
      ='\n'
      //.hero-banner__item
      .hero-banner__item(data-indicator=val.indicator)
        if val.image
          .hero-banner__img
            ='\n'
            img.hero-banner__img__el(src=val.image alt=val.title)/
        if val.video
          .hero-banner__video
            ='\n'
            video.hero-banner__video-el(loop="" muted="" playsinline="" autoplay)
              ='\n'
              source(src=val.video type="video/mp4")
        .hero-banner__content
          .container
            .hero-banner__text
              if val.label
                .hero-banner__tag
                  i.sr-factory.hero-banner__tag__icon
                  span.hero-banner__tag__text= val.label
              if idx === 0
                h1.hero-banner__title= val.title
              else
                 h2.hero-banner__title= val.title
              p.hero-banner__desc= val.description
              if val.btn
                .hero-banner__btn
                  ='\n'
                  a.btn.btn--secondary.btn--icon(href=val.btn.link target="_blank")
                    ='\n'
                    span.btn__text= val.btn.text
                    ='\n'
                    i.sr.sr-caret-right
                    ='\n'
