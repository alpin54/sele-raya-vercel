//-------------------------------------------------------------------------------
// @name: Career Section
//-------------------------------------------------------------------------------

.career-mosaic
  .container
    .career-mosaic-inner
      .career-mosaic-head
        h6.career-mosaic-subtitle !{data.subtitle}
        h1.career-mosaic-title !{data.title}
      .career-mosaic-body
        each col, index in data.cols
          .career-mosaic__col(class='career-mosaic__col--' + (index + 1))
            each item in col.items
              .career-mosaic__item
                if item.type === 'image'
                  .career-mosaic__item-img
                    img.career-mosaic__item-img-el(
                      src='assets/img/dummy/' + item.src,
                      alt=item.alt || 'career image'
                    )

                else if item.type === 'video'
                  .career-mosaic__item-video
                    video.career-mosaic__item-video-el(autoplay muted loop playsinline)
                      source(
                        src='assets/video/' + item.src,
                        type='video/mp4'
                      )

='\n'
